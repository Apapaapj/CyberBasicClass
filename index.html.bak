//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//
// OWNER ADD BALANCE
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//

bot.command('addbalance', (ctx) => {

if (String(ctx.from.id) !== OWNER_ID)
return ctx.reply('❌ Owner Only')

const args = ctx.message.text.split(' ')

const targetId = Number(args[1])
const amount = Number(args[2])

const users = loadDB()

const user = users.find(
u => u.id === targetId
)

if (!user)
return ctx.reply('User not found')

user.balance += amount

saveDB(users)

ctx.reply(`
✅ Balance Added

💰 +${amount}
`)
})

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//
// OWNER ADD PREMIUM
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//

bot.command('addprem', (ctx) => {

if (String(ctx.from.id) !== OWNER_ID)
return ctx.reply('❌ Owner Only')

const targetId =
Number(ctx.message.text.split(' ')[1])

const users = loadDB()

const user = users.find(
u => u.id === targetId
)

if (!user)
return ctx.reply('User not found')

user.premium = true

saveDB(users)

ctx.reply(`
💎 Premium Added
`)
})

