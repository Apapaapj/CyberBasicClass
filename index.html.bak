//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//
// DAILY
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//

bot.command('daily', (ctx) => {

const users = loadDB()

const user = users.find(
u => u.id === ctx.from.id
)

const reward = Math.floor(Math.random() * 5000)

user.balance += reward

saveDB(users)

ctx.reply(`
🎁 DAILY REWARD

💰 +${reward}
`)
})

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//
// LEADERBOARD
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//

bot.command('leaderboard', (ctx) => {

const users = loadDB()

const sorted = users.sort(
(a,b) => b.balance - a.balance
)

let text = `🏆 TOP USERS\n`

sorted.slice(0,10).forEach((u,i) => {

text += `
${i+1}. ${u.name}
💰 ${u.balance}
`

})

ctx.reply(text)

})

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//
// IP LOOKUP
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//

bot.command('ip', async(ctx) => {

const ip = ctx.message.text.split(' ')[1]

if (!ip)
return ctx.reply('Example: /ip 8.8.8.8')

try {

const res = await axios.get(
`http://ip-api.com/json/${ip}`
)

const d = res.data

ctx.reply(`
🌐 IP LOOKUP

IP : ${d.query}
Country : ${d.country}
City : ${d.city}
ISP : ${d.isp}
`)

} catch {

ctx.reply('Failed.')

}

})

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//
// DNS LOOKUP
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//

bot.command('dns', (ctx) => {

const domain = ctx.message.text.split(' ')[1]

if (!domain)
return ctx.reply('Example: /dns google.com')

dns.lookup(domain, (err,address) => {

if (err)
return ctx.reply('DNS Failed')

ctx.reply(`
🌍 DNS LOOKUP

Domain : ${domain}
IP : ${address}
`)

})

})

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//
// HTTP STATUS
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//

bot.command('httpstatus', async(ctx) => {

const url = ctx.message.text.split(' ')[1]

if (!url)
return ctx.reply('Example: /httpstatus https://google.com')

try {

const res = await axios.get(url)

ctx.reply(`
🌐 HTTP STATUS

${res.status}
`)

} catch {

ctx.reply('Request Failed')

}

})

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//
// HASH
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//

bot.command('hash', (ctx) => {

const text = ctx.message.text.split(' ').slice(1).join(' ')

if (!text)
return ctx.reply('Example: /hash hello')

const hash = crypto
.createHash('sha256')
.update(text)
.digest('hex')

ctx.reply(`
🔒 SHA256

${hash}
`)

})

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//
// BASE64
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//

bot.command('base64', (ctx) => {

const text = ctx.message.text.split(' ').slice(1).join(' ')

if (!text)
return ctx.reply('Example: /base64 hello')

const result =
Buffer.from(text).toString('base64')

ctx.reply(`
🔐 BASE64

${result}
`)

})

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//
