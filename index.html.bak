//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//

const { Telegraf } = require('telegraf')
const axios = require('axios')
const dns = require('dns')
const os = require('os')
const fs = require('fs')
const crypto = require('crypto')
const chalk = require('chalk')
const moment = require('moment-timezone')

const bot = new Telegraf('8286438302:AAEibrz61iF3JpVV9vLLneYSTGJ_8_aVOO4')
const OWNER_ID = '8229333628'

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//
// DATABASE
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//

const dbFile = './users.json'

if (!fs.existsSync(dbFile)) {
fs.writeFileSync(dbFile, JSON.stringify([]))
}

const loadDB = () => {
return JSON.parse(fs.readFileSync(dbFile))
}

const saveDB = (data) => {
fs.writeFileSync(dbFile, JSON.stringify(data, null, 2))
}

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//
// AUTO REGISTER USER
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//

bot.use((ctx, next) => {

if (!ctx.from) return next()

const users = loadDB()

const userId = ctx.from.id

const user = users.find(u => u.id === userId)

if (!user) {

users.push({

id: userId,
name: ctx.from.first_name,
username: ctx.from.username || 'No Username',
balance: 0,
premium: false,
level: 1,
xp: 0,
joined: new Date().toLocaleString()

})

saveDB(users)

console.log(`
[NEW USER]
${ctx.from.first_name}
`)
}

next()

})

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//
// ANTI SPAM
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//

const spamMap = new Map()

bot.use((ctx, next) => {

if (!ctx.from) return next()

const userId = ctx.from.id
const now = Date.now()

if (!spamMap.has(userId)) {

spamMap.set(userId, {
count: 1,
last: now,
mute: 0
})

return next()

}

const data = spamMap.get(userId)

if (data.mute > now) {

return ctx.reply(`
🚫 Anti Spam

⏳ Tunggu sebentar.
`)

}

if (now - data.last < 5000) {

data.count++

} else {

data.count = 1

}

data.last = now

if (data.count >= 7) {

data.mute = now + 30000

return ctx.reply(`
🚨 Spam Detected

🔒 Muted 30 Detik
`)

}

next()

})

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//
// LEVEL SYSTEM
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━//

bot.use((ctx, next) => {

if (!ctx.from) return next()

const users = loadDB()

const user = users.find(
u => u.id === ctx.from.id
)

if (user) {

user.xp += 10

const need = user.level * 100

if (user.xp >= need) {

user.level += 1
user.xp = 0

ctx.reply(`
🎉 LEVEL UP

⬆️ Level ${user.level}
`)

}

saveDB(users)

}

next()

})

